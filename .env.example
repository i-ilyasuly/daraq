# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=""

# Cohere API Key (Required for ReRanker in RAG)
COHERE_API_KEY=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Telegram Bot Token
TELEGRAM_BOT_TOKEN=""

# Qdrant Database Configuration
QDRANT_URL=""
QDRANT_API_KEY=""

# Google Cloud Storage (Bucket Name)
GCS_BUCKET_NAME=""

# ElevenLabs Speech-to-Text API Key
ELEVENLABS_API_KEY=""

# Restricted Web Search API Configuration (For modern fatwas and fallback search)
VERTEX_DATA_STORE_ID=""
GOOGLE_PROJECT_ID=""

# Firebase Admin configuration
# Required for Firestore (Chat history)
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
# Note: FIREBASE_PRIVATE_KEY should be added to actual .env or secrets
FIREBASE_PRIVATE_KEY=""

# Configurable Models for Gemini API
GEMINI_EMBEDDING_MODEL="gemini-embedding-2"
GEMINI_GENERATION_MODEL="gemini-flash-lite-latest"
GEMINI_INTENT_MODEL="gemini-flash-lite-latest"
